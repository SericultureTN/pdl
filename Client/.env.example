# API Configuration for Vercel Deployment
# Your backend API URL - deployed on Vercel
VITE_API_URL=https://pdltn.vercel.app/api

# Environment
NODE_ENV=production

# App Configuration
VITE_APP_NAME=PDL Admin Portal
VITE_APP_VERSION=1.0.0

# Instructions:
# 1. Deploy your Node.js backend to Vercel
# 2. Set VITE_API_URL in Vercel dashboard environment variables
# 3. Make sure your backend is accessible at the API URL
# 4. Test the API endpoints (/health, /api/login, etc.)
