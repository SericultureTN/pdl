# API Configuration for Local Development
# Your backend API URL - running locally
VITE_API_URL=http://localhost:4000/api

# Environment
NODE_ENV=development

# App Configuration
VITE_APP_NAME=PDL Admin Portal
VITE_APP_VERSION=1.0.0

# Instructions:
# 1. Start backend: cd Node && npm run dev-sqlite
# 2. Set VITE_API_URL in your local environment
# 3. Start frontend: npm run dev
# 4. Test the application at http://localhost:5173
