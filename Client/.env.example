# API Configuration for Vercel Deployment
# IMPORTANT: You need to deploy your backend separately and set the correct URL
# Examples:
# - For Render: https://your-app.onrender.com/api
# - For Railway: https://your-app.railway.app/api
# - For Heroku: https://your-app.herokuapp.com/api
# - For DigitalOcean: https://your-app.digitaloceanapp.com/api
# - For local development: http://localhost:4000/api

VITE_API_URL=https://your-backend-deployment-url.com/api

# Environment
NODE_ENV=production

# App Configuration
VITE_APP_NAME=PDL Admin Portal
VITE_APP_VERSION=1.0.0

# Instructions:
# 1. Deploy your Node.js backend to a hosting service (Render, Railway, etc.)
# 2. Update VITE_API_URL with your actual backend URL
# 3. Set VITE_API_URL in Vercel dashboard environment variables
# 4. Make sure your backend is accessible and running
# 5. Test the API endpoints (/health, /api/login, etc.)
