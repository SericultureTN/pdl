# ─── PostgreSQL (required for npm run dev-postgres) ───
# Option A: single connection string (recommended)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/pdl

# Option B: individual variables (used if DATABASE_URL is not set)
# PGUSER=postgres
# PGPASSWORD=YOUR_PASSWORD
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=pdl

# ─── Server ───
PORT=4000
JWT_SECRET=local_dev_secret_change_me_in_production
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# For LAN access, also add your PC IP, e.g.:
# CORS_ORIGIN=http://localhost:5173,http://192.168.1.100:5173

# ─── Notes ───
# 1. Copy this file: npm run setup:env
# 2. Replace YOUR_PASSWORD with your local PostgreSQL password
# 3. Create the database first: createdb pdl  (or via pgAdmin)
# 4. For zero-config local dev, use SQLite instead: npm run dev-sqlite
